# EditorConfig -- https://editorconfig.org
root = true

# Defaults for all files: LF, UTF-8, trim trailing whitespace, final newline.
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# Rust source
[*.rs]
indent_size = 4

# TOML config
[*.toml]
indent_size = 4

# YAML
[*.{yml,yaml}]
indent_size = 2

# Makefile -- tabs required
[Makefile]
indent_style = tab

# Shell scripts
[*.sh]
indent_size = 2

# Markdown -- trailing whitespace can be intentional (line breaks)
[*.md]
trim_trailing_whitespace = false
